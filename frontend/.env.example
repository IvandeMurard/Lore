# Speechmatics — STT
SPEECHMATICS_API_KEY=
# Optional override (auto-fallback also tries trial/eu/us endpoints)
SPEECHMATICS_ASR_BASE_URL=https://asr.api.speechmatics.com
# Optional override for realtime token minting
SPEECHMATICS_MANAGEMENT_BASE_URL=https://mp.speechmatics.com
# Optional override for realtime websocket host (example: eu2.rt.speechmatics.com)
NEXT_PUBLIC_SPEECHMATICS_RT_WS_ENDPOINT=

# LLM
OPENAI_API_KEY=
# or
ANTHROPIC_API_KEY=

# Vector DB (Qdrant Cloud)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=lore_knowledge

# TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
