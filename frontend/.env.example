# Speechmatics — STT
SPEECHMATICS_API_KEY=
# Optional override (auto-fallback also tries trial/eu/us endpoints)
SPEECHMATICS_ASR_BASE_URL=https://asr.api.speechmatics.com
# Optional override for realtime token minting
SPEECHMATICS_MANAGEMENT_BASE_URL=https://mp.speechmatics.com
# Optional override for realtime websocket host (example: eu2.rt.speechmatics.com)
NEXT_PUBLIC_SPEECHMATICS_RT_WS_ENDPOINT=

# LLM
OPENAI_API_KEY=
# Optional if you keep Anthropic tooling around
ANTHROPIC_API_KEY=

# Backboard — memory and retrieval
BACKBOARD_API_KEY=
BACKBOARD_ASSISTANT_ID=
BACKBOARD_THREAD_F_GKXA=
BACKBOARD_THREAD_F_HBXA=
BACKBOARD_THREAD_MARC_DELAUNAY=

# OpenAI — TTS
# Models: gpt-4o-mini-tts (fast) | tts-1 | tts-1-hd
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Voices: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=alloy
# Formats: mp3 | wav | opus | aac | flac | pcm
OPENAI_TTS_FORMAT=opus

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
